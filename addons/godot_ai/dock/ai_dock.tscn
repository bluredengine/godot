[gd_scene load_steps=2 format=3 uid="uid://dock_ai_main"]

[ext_resource type="Script" path="res://addons/godot_ai/dock/ai_dock.gd" id="1_script"]

[node name="AIDock" type="Control"]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_script")

[node name="VBoxContainer" type="VBoxContainer" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="Header" type="HBoxContainer" parent="VBoxContainer"]
layout_mode = 2

[node name="Title" type="Label" parent="VBoxContainer/Header"]
layout_mode = 2
text = "AI Assistant"
theme_override_font_sizes/font_size = 16

[node name="HSeparator" type="HSeparator" parent="VBoxContainer/Header"]
layout_mode = 2
size_flags_horizontal = 3

[node name="ConnectionIndicator" type="ColorRect" parent="VBoxContainer/Header"]
unique_name_in_owner = true
custom_minimum_size = Vector2(12, 12)
layout_mode = 2
color = Color(0.5, 0.5, 0.5, 1)

[node name="Toolbar" type="HBoxContainer" parent="VBoxContainer"]
layout_mode = 2

[node name="TemplateButton" type="MenuButton" parent="VBoxContainer/Toolbar"]
unique_name_in_owner = true
layout_mode = 2
text = "Templates"

[node name="ClearButton" type="Button" parent="VBoxContainer/Toolbar"]
unique_name_in_owner = true
layout_mode = 2
text = "Clear"

[node name="ReconnectButton" type="Button" parent="VBoxContainer/Toolbar"]
unique_name_in_owner = true
layout_mode = 2
text = "Reconnect"

[node name="HSeparator2" type="HSeparator" parent="VBoxContainer/Toolbar"]
layout_mode = 2
size_flags_horizontal = 3

[node name="StatusLabel" type="Label" parent="VBoxContainer/Toolbar"]
unique_name_in_owner = true
layout_mode = 2
text = "Ready"
theme_override_colors/font_color = Color(0, 1, 0, 1)
theme_override_font_sizes/font_size = 11

[node name="ChatScroll" type="ScrollContainer" parent="VBoxContainer"]
unique_name_in_owner = true
layout_mode = 2
size_flags_vertical = 3
horizontal_scroll_mode = 0

[node name="ChatContainer" type="VBoxContainer" parent="VBoxContainer/ChatScroll"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3

[node name="WelcomeMessage" type="RichTextLabel" parent="VBoxContainer/ChatScroll/ChatContainer"]
layout_mode = 2
bbcode_enabled = true
text = "[color=gray]Welcome to GodotAI![/color]

Describe what you want to create, or select a template to get started.

[color=cyan]Examples:[/color]
- \"Create a 2D platformer\"
- \"Add a player character\"
- \"Make the enemy follow the player\""
fit_content = true

[node name="HSeparator" type="HSeparator" parent="VBoxContainer"]
layout_mode = 2

[node name="InputContainer" type="VBoxContainer" parent="VBoxContainer"]
layout_mode = 2

[node name="PromptInput" type="TextEdit" parent="VBoxContainer/InputContainer"]
unique_name_in_owner = true
custom_minimum_size = Vector2(0, 60)
layout_mode = 2
placeholder_text = "Describe what you want to create..."
wrap_mode = 1

[node name="SendButton" type="Button" parent="VBoxContainer/InputContainer"]
unique_name_in_owner = true
layout_mode = 2
text = "Send (Enter)"
